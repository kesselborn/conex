{
  "manifest_version": 3,
  "action": {
    "default_title": "Conex",
    "default_popup": "browser-action.html",
    "default_icon": "./icons/icon.svg"
  },
  "author": "Daniel Bornkessel",
  "background": {
    "type": "module",
    "scripts": [
      "background.js"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "conex@bornkessel.com",
      "strict_min_version": "60.0a1",
      "update_url": "https://raw.githubusercontent.com/kesselborn/conex/main/versions.json"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Space",
        "mac": "MacCtrl+Space"
      },
      "description": "__MSG_commandExecuteAction__"
    },
    "new-container": {
      "suggested_key": {
        "default": "Alt+Shift+N"
      },
      "description": "__MSG_commandNewContainer__"
    }
  },
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "developer": {
    "name": "Daniel Kesselborn",
    "url": "https://github.com/kesselborn/conex"
  },
  "homepage_url": "https://github.com/kesselborn/conex",
  "name": "Conex (preview)",
  "version": "0.10.3",
  "options_ui": {
    "page": "options-ui.html",
    "open_in_tab": false
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "incognito": "spanning",
  "permissions": [
    "contextualIdentities",
    "cookies",
    "storage",
    "tabs"
  ],
  "optional_permissions": [
    "<all_urls>",
    "activeTab",
    "bookmarks",
    "browserSettings",
    "history",
    "notifications",
    "tabHide",
    "webNavigation",
    "webRequest",
    "webRequestBlocking"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "container-selector.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
